/* ———————————————————————————————————————
   1. 全局基础样式
——————————————————————————————————————— */
QMainWindow {
    background-color: #F7F8FA; /* 超浅灰*/
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;;
    font-size: 14px;
}

QWidget {
    outline: none; /* 去掉选中虚线框 */
}

/* ———————————————————————————————————————
   2. 卡片容器 QGroupBox
——————————————————————————————————————— */
QGroupBox {
    background-color: #FFFFFF;
    border: none;
    border-radius: 10px;
    margin-top: 14px;
    padding: 8px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 8px;
    color: #4E5969;
    font-weight: bold;
    font-size: 15px;
}

/* ———————————————————————————————————————
   3. 左侧导航按钮
——————————————————————————————————————— */
QPushButton#btnNav {
    background-color: transparent;
    color: #555;
    border: none;
    border-radius: 6px;
    padding: 12px 10px;
    text-align: left;
    font-size: 15px;
}

QPushButton#btnNav:hover {
    background-color: #E8F4FF;
    color: #2B98F0;
}

QPushButton#btnNav:pressed,
QPushButton#btnNav:checked {
    background-color: #2B98F0;
    color: #FFF;
}

/* ———————————————————————————————————————
   4. 普通功能按钮
——————————————————————————————————————— */
QPushButton {
    background-color: #2B98F0; /* 医疗科技蓝 */
    color: white;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    border: none;
}

QPushButton:hover {
    background-color: #1E88E5;
}

QPushButton:pressed {
    background-color: #1976D2;
}

QPushButton:disabled {
    background-color: #C0D6EF;
    color: #EEE;
}

/* ———————————————————————————————————————
   5. 指示灯样式
——————————————————————————————————————— */
/* 绿色正常灯 */
QLabel.led-green {
    background-color: #00B42A;
    border-radius: 9px;
    min-width: 18px;
    min-height: 18px;
}

/* 红色报警灯 */
QLabel.led-red {
    background-color: #F53F3F;
    border-radius: 9px;
    min-width: 18px;
    min-height: 18px;
}

/* 灰色离线/待机灯 */
QLabel.led-gray {
    background-color: #909399;
    border-radius: 9px;
    min-width: 18px;
    min-height: 18px;
}

/* ———————————————————————————————————————
   6. 报警文字
——————————————————————————————————————— */
QLabel.text-alarm {
    color: #F53F3F;
    font-weight: bold;
}

/* 正常数值大字 */
QLabel.text-value {
    font-size: 24px;
    font-weight: bold;
    color: #303133;
}

/* ———————————————————————————————————————
   7. LCD 数字显示
——————————————————————————————————————— */
QLCDNumber {
    background-color: #2C2E34;
    color: #00E4FF; /* 医疗仪器青蓝色 */
    border-radius: 6px;
    border: 1px solid #DCDFE6;
}

/* ———————————————————————————————————————
   8. 日志框
——————————————————————————————————————— */
QTextBrowser#logBrowser {
    background-color: #1E1E2E;
    color: #A9E0B0;
    border-radius: 6px;
    border: none;
    padding: 8px;
    font-family: &quot;Consolas&quot;;
    font-size: 13px;
}

/* ———————————————————————————————————————
   9. 输入框、下拉框、时间选择
——————————————————————————————————————— */
QDoubleSpinBox, QComboBox, QDateTimeEdit {
    background-color: #FFFFFF;
    border: 1px solid #DCDFE6;
    border-radius: 6px;
    padding: 6px 8px;
    color: #333;
}

QDoubleSpinBox:focus, QComboBox:focus, QDateTimeEdit:focus {
    border: 1px solid #2B98F0;
}

/* ———————————————————————————————————————
   10. 进度条
——————————————————————————————————————— */
QProgressBar {
    border: none;
    background-color: #EAECEF;
    border-radius: 4px;
    height: 8px;
}

QProgressBar::chunk {
    background-color: #2B98F0;
    border-radius: 4px;
}</string>
